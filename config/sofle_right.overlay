#include <dt-bindings/led/led.h>

/* --- I2C BUS: TRACKPAD ONLY --- */
&pro_micro_i2c {
    status = "okay";

    /* 1. Trackpad (Address 0x74) */
    tps65: iqs5xx@74 {
        compatible = "azoteq,iqs5xx";
        status = "okay";
        reg = <0x74>;

        /* Interrupt & Ready Pins */
        /* Ensure these pin numbers match your Right Side physical wiring! */
        reset-gpios = <&pro_micro 4 GPIO_ACTIVE_LOW>;
        rdy-gpios = <&pro_micro 0 GPIO_ACTIVE_HIGH>;

        /* Settings */
        one-finger-tap;
        press-and-hold;
        press-and-hold-time = <250>;
        two-finger-tap;
        scroll;
        natural-scroll-x;
        bottom-beta = <15>;
        stationary-threshold = <5>;
        switch-xy;

        /* TPS65 SPECIFIC RESOLUTION FIX */
        /* If your driver supports these properties, uncomment them. */
        /* If not, you MUST edit the C driver code as discussed previously. */
        // x-resolution = <3072>;
        // y-resolution = <2048>;
    };

    /* 2. OLED Display - DISABLED */
    /* Disabled to prevent I2C bus hangs */
    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        status = "disabled";  /* CHANGED FROM OKAY */
        reg = <0x3c>;
        width = <128>;
        height = <32>;
        segment-offset = <0>;
        page-offset = <0>;
        display-offset = <0>;
        multiplex-ratio = <31>;
        segment-remap;
        com-invdir;
        com-sequential;
        prechargep = <0x22>;
    };
};

/* --- LEDS (SPI3) --- */
&pinctrl {
    spi3_default: spi3_default { group1 { psels = <NRF_PSEL(SPIM_MOSI, 0, 6)>; }; };
    spi3_sleep: spi3_sleep { group1 { psels = <NRF_PSEL(SPIM_MOSI, 0, 6)>; low-power-enable; }; };
};

&spi3 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi3_default>;
    pinctrl-1 = <&spi3_sleep>;
    
    led_strip: ws2812@0 {
        compatible = "worldsemi,ws2812-spi";
        reg = <0>;
        spi-max-frequency = <4000000>;
        chain-length = <29>;
        spi-one-frame = <0x70>;
        spi-zero-frame = <0x40>;
        color-mapping = <LED_COLOR_ID_GREEN LED_COLOR_ID_RED LED_COLOR_ID_BLUE>;
    };
};

/* --- ROOT SELECTION --- */
/ {
    tps65_input: tps65_input {
        compatible = "zmk,input-listener";
        device = <&tps65>;
    };

    chosen {
        zmk,underglow = &led_strip;
        /* zmk,display = &oled;  <-- REMOVED or COMMENTED OUT */
    };
};
