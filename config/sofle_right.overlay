#include <dt-bindings/led/led.h>
#include <dt-bindings/zmk/input_transform.h> 
#include <dt-bindings/input/input-event-codes.h> /* <--- REQUIRED for INPUT_REL_X/Y */
#include "sofle.dtsi"

/* --- 1. DEFINE THE PROCESSOR --- */
/ {
    zip_xy_transform: zip_xy_transform {
        compatible = "zmk,input-processor-transform";
        #input-processor-cells = <1>;
        
        /* These two lines were missing and caused the error: */
        type = <INPUT_EV_REL>;
        x-codes = <INPUT_REL_X>;
        y-codes = <INPUT_REL_Y>;
    };
};

/* --- 2. HARDWARE CONFIG --- */
&pro_micro_i2c {
    status = "okay";

    /* Local Trackpad (TPS65) */
    tps65: iqs5xx@74 {
        compatible = "azoteq,iqs5xx";
        status = "okay";
        reg = <0x74>;
        reset-gpios = <&pro_micro 4 GPIO_ACTIVE_LOW>;
        rdy-gpios = <&pro_micro 0 GPIO_ACTIVE_HIGH>;

        /* Standard Settings */
        one-finger-tap;
        press-and-hold;
        press-and-hold-time = <250>;
        two-finger-tap;
        scroll;
        natural-scroll-x;
        bottom-beta = <15>;
        stationary-threshold = <5>;
    };

    /* OLED Display - DISABLED */
    oled: ssd1306@3c {
        compatible = "solomon,ssd1306fb";
        status = "disabled"; 
        reg = <0x3c>;
    };
};

/* --- 3. SPLIT BINDING (Apply Rotation) --- */
&right_trackpad_split {
    device = <&tps65>;
    
    /* Logic: SWAP X/Y, then INVERT Y to fix "Left moves Down" */
    input-processors = <&zip_xy_transform (INPUT_TRANSFORM_XY_SWAP | INPUT_TRANSFORM_Y_INVERT)>;
};
